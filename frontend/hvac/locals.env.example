# Copy this file to locals.env and fill values for local runs.
# locals.env is git-ignored and should contain sensitive identifiers.

# App mode settings
LOCAL_AUTH_MODE=cognito
LOCAL_PROPOSAL_API_MODE=mock
# If this URL is set and LOCAL_PROPOSAL_WIZARD_API_MODE is omitted,
# wizard mode defaults to http automatically.
LOCAL_PROPOSAL_WIZARD_API_BASE_URL=
# Optional explicit override: http or mock
# LOCAL_PROPOSAL_WIZARD_API_MODE=http

# Cognito settings
LOCAL_COGNITO_USER_POOL_ID=
LOCAL_COGNITO_USER_POOL_CLIENT_ID=
LOCAL_COGNITO_DOMAIN=

# Frontend base URL used for OAuth callback/logout paths
LOCAL_FRONTEND_BASE_URL=http://localhost:4200

# Optional comma-separated list of local origins
LOCAL_COGNITO_LOCAL_ORIGINS=http://localhost:4200,http://localhost:8080
